# Backend Environment Variables
# Copy this file to .env and update with your actual values

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/algochat

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Custom OTP / SMS (Twilio removed)
# Provider: console | fast2sms | msg91
# - console: OTP only in server terminal (local dev)
# - fast2sms: real SMS in India — https://www.fast2sms.com (free credits)
# - msg91: real SMS in India — https://msg91.com
SMS_PROVIDER=fast2sms
FAST2SMS_API_KEY=your-fast2sms-api-key

# MSG91 (if SMS_PROVIDER=msg91)
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-otp-template-id

OTP_EXPIRY_MINUTES=5

# Server Configuration
NODE_ENV=development
PORT=5001
